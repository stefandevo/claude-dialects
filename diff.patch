diff --git a/internal/app/staleness_helpers.go b/internal/app/staleness_helpers.go
new file mode 100644
index 0000000..dccb735
--- /dev/null
+++ b/internal/app/staleness_helpers.go
@@ -0,0 +1,42 @@
+package app
+
+import (
+	"os"
+	"strings"
+)
+
+func proxySpawnVersion(name string) string {
+	_, _, _, _, _, _, versionPath, err := paths(name)
+	if err != nil {
+		return ""
+	}
+	raw, err := os.ReadFile(versionPath)
+	if err != nil {
+		return ""
+	}
+	return strings.TrimSpace(string(raw))
+}
+
+func cursorBridgeSpawnVersion(name string) string {
+	_, _, _, versionPath, err := cursorInstancePaths(name)
+	if err != nil {
+		return ""
+	}
+	raw, err := os.ReadFile(versionPath)
+	if err != nil {
+		return ""
+	}
+	return strings.TrimSpace(string(raw))
+}
+
+func copilotBridgeSpawnVersion(name string) string {
+	_, _, _, versionPath, err := copilotInstancePaths(name)
+	if err != nil {
+		return ""
+	}
+	raw, err := os.ReadFile(versionPath)
+	if err != nil {
+		return ""
+	}
+	return strings.TrimSpace(string(raw))
+}
